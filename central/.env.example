# ─────────────────────────────────────────────────────────────────────────────
# Honeypot Central Server – .env
# Скопируйте в central/.env и заполните
# ─────────────────────────────────────────────────────────────────────────────

# Секретный токен для доступа в веб-интерфейс
ADMIN_TOKEN=change-me-to-something-strong

# Через сколько секунд нода считается offline (по умолчанию 900 = 15 мин)
# ONLINE_SECS=900

# Имя address-list в MikroTik RouterOS (по умолчанию honeypot-block)
# MIKROTIK_LIST_NAME=honeypot-block

# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# Вариант 1: Let's Encrypt через certbot (требует публичный домен и открытый порт 80)
#   CERTBOT_DOMAIN=central.example.com
#   CERTBOT_EMAIL=admin@example.com
#   CERTBOT_STAGING=0          # 1 для тестирования без лимитов LE
#   CERTBOT_HTTP_PORT=80       # порт для HTTP-01 challenge (по умолчанию 80)
#
# Вариант 2: Самоподписанный сертификат (генерируется автоматически на 10 лет)
#   Если переменные CERTBOT_DOMAIN / CERTBOT_EMAIL не заданы — используется этот вариант.
#   SSL_CN=honeypot-central    # CN в самоподписанном сертификате (опционально)
