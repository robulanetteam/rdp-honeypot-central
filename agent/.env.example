# ─────────────────────────────────────────────────────────────────────────────
# Honeypot Central Agent – добавьте эти строки в .env вашего honeypot-проекта
# ─────────────────────────────────────────────────────────────────────────────

# URL центрального сервера управления
CENTRAL_URL=http://192.168.90.1:8100

# Уникальный идентификатор этой ноды (создаётся в UI → Settings)
CENTRAL_NODE_ID=rdp-home

# Токен аутентификации (выдаётся при регистрации ноды в UI → Settings)
CENTRAL_TOKEN=REPLACE_WITH_TOKEN_FROM_CENTRAL_UI

# Путь к папке data/ вашего honeypot (на хост-машине)
CENTRAL_DATA_DIR=/home/homeserver/rdp_honeypot/rdp_honeypot/data

# (Опционально) Пропустить проверку TLS-сертификата (1 = да)
# CENTRAL_INSECURE=0

# (Опционально) За сколько дней отправлять analytics (по умолчанию 7)
# CENTRAL_ANALYTICS_DAYS=7
